unalias gz 2>/dev/null || true

export DEMO_WS="$PWD/ros_ws"
export ROS_LOCALHOST_ONLY="${ROS_LOCALHOST_ONLY:-1}"

if [ -f "$DEMO_WS/install/setup.sh" ]; then
  source "$DEMO_WS/install/setup.sh"
fi

